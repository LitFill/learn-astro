---

import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import "../styles/global.css"

const page_title = "Tentang Aku"

const identity = {
	name:    "LitFill",
	country: "Indonesia",
	likes:   [ "Haskell"
			 , "Koka"
			 , "Lisps"
			 , "Nix"
			 ],
}

const state    = "ok";
const finished = false;
const limit    = 3;

const style_vars = {
    skill_color: "crimson",
    font_weight: "bold",
    text_case  : "uppercase",
};

style_vars["skill_color"] = finished ? "crimson" : "green";

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{page_title}</title>
		<style define:vars={style_vars}>
		h1 {
			color:     purple;
			font-size: 4rem;
		}
		.skill {
			color:          var(--skill_color);
			font-weight:    var(--font_weight);
			text-transform: var(--text_case);
		}
		</style>
	</head>
	<body>
		<header><Nav /></header>
		<main>
			<section>
				<h1>{page_title}</h1>
				<h2>... and my new Astro site!</h2>
				<p>Guided through Astro docs tutorial.</p>
				<p>This will be updated.</p>
			</section>
			<section>
				<p>Some of me:</p>
				<ul class="identity">
					<li>Name is {identity.name}.</li>
					<li>From {identity.country}.</li>
					{ identity.likes.length >= 2 &&
						<li>Really likes { identity.likes[0] } and { identity.likes[1] }.</li> }
				</ul>
				<p>ProgLangs:</p>
				<ul>
					{ identity.likes.map((skill) =>
						<li class="skill">{ skill }</li>) }
				</ul>
			</section>
			<section>
				{ state === "ok" && <p>I am ok!</p> }
				{ finished && <p><b>This tutorial is finished.</b></p> }
				{ limit == 3
					? <p>The deadline is in 3 days.</p>
					: <p>The deadline is in { limit } days.</p>
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
